APP_NAME=SyaJagad
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-project.vercel.app

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

LOG_CHANNEL=stderr
LOG_LEVEL=warning
VIEW_COMPILED_PATH=/tmp/syajagad/framework/views

DB_CONNECTION=pgsql
DATABASE_URL=
DB_PORT=5432
DB_SSLMODE=require

# Cookie session dan array cache membuat request awal tidak gagal hanya karena
# table sessions/cache belum siap atau database sedang cold start.
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

CACHE_STORE=array
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

MAIL_MAILER=log
MAIL_FROM_ADDRESS=admin@syajagad.local
MAIL_FROM_NAME="${APP_NAME}"

MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_TIMEOUT=12

VITE_APP_NAME="${APP_NAME}"
